# GPT (OpenAI-compatible)
GPT_BASE_URL=https://api.openai.com/v1
GPT_API_KEY=your_api_key_here
GPT_MODEL=gpt-4.1-mini

# Gemini (OpenAI-compatible Google endpoint)
GEMINI_BASE_URL=
GEMINI_API_KEY=
GEMINI_MODEL=

# Xiaomi MiMo (OpenAI-compatible token plan)
XIAOMI_BASE_URL=
XIAOMI_API_KEY=
XIAOMI_MODEL=mimo-v2.5-pro

# Claude (OpenAI-compatible endpoint)
CLAUDE_BASE_URL=
CLAUDE_API_KEY=
CLAUDE_MODEL=

# Legacy fallback for GPT when GPT_* are unset
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=

# Optional: max assistant tool rounds per chat send (default 128, max 128).
# AGENT_TOOL_LOOP_MAX=128
# Disable agent session persistence (isolates sync I/O during beach-ball debugging).
# DARTSNUT_DISABLE_AGENT_SESSION_PERSISTENCE=1
