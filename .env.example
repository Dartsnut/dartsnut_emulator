# OpenAI-compatible Chat Completions base (must include /v1), e.g. OpenAI or Xiaomi MiMo token plan.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=mimo-v2.5-pro
# Optional: max assistant tool rounds per chat send (default 128, max 128).
# AGENT_TOOL_LOOP_MAX=128
# Disable agent session persistence (isolates sync I/O during beach-ball debugging).
# DARTSNUT_DISABLE_AGENT_SESSION_PERSISTENCE=1
