# OpenAI-compatible Chat Completions base (must include /v1), e.g. OpenAI or Xiaomi MiMo token plan.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=mimo-v2.5-pro
# Optional: max assistant tool rounds per chat send (default 32, max 128).
# AGENT_TOOL_LOOP_MAX=32
#
# Optional: disable HTTP streaming when tool messages are in context (uses one-shot completions instead).
# Default is streaming ON so reasoning/content deltas work after tool rounds. Set if your gateway errors.
# AGENT_DISABLE_STREAM_WITH_TOOL_HISTORY=1
