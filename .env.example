# Optional bootstrap for LLM settings (Settings → OpenAI key configure).
# Saved app settings take precedence; empty fields fall back to GPT_* then OPENAI_*.
GPT_BASE_URL=https://api.openai.com/v1
GPT_API_KEY=your_api_key_here
GPT_MODEL=gpt-4.1-mini

# Built-in Settings → Dartsnut LLM provider.
# The app fetches URL, token key, and model from https://api.dartsnut.com/mobile/system/model at launch.
# This build-time key decrypts that encrypted response.
DARTSNUT_MODEL_DECRYPTION_KEY=

# Legacy fallback when GPT_* are unset
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=

# Dartsnut community / deploy device picker (optional; defaults to production hosts)
# DARTSNUT_BASE_API=https://api.dartsnut.com
# DARTSNUT_SUPABASE_URL=https://base.dartsnut.com
# DARTSNUT_SUPABASE_ANON_KEY=
# DARTSNUT_SUPABASE_DEVICE_TABLE=remote_devices
# Legacy renderer/web Google client ID for direct ID-token login.
# DARTSNUT_GOOGLE_CLIENT_ID=
# Electron desktop Google OAuth client ID; enables "Continue with Google".
# DARTSNUT_GOOGLE_DESKTOP_CLIENT_ID=
# Optional for desktop clients whose token endpoint requires it.
# DARTSNUT_GOOGLE_DESKTOP_CLIENT_SECRET=

# Optional: max assistant tool rounds per chat send (default 128, max 128).
# AGENT_TOOL_LOOP_MAX=128
# Disable agent session persistence (isolates sync I/O during beach-ball debugging).
# DARTSNUT_DISABLE_AGENT_SESSION_PERSISTENCE=1
