# Copy this file to `.env.macos-notarize` in this directory (that file is gitignored).
# App-specific password: https://appleid.apple.com → Sign-In and Security → App-Specific Passwords
# Team ID: https://developer.apple.com/account → Membership
APPLE_ID=
APPLE_APP_SPECIFIC_PASSWORD=
APPLE_TEAM_ID=

# Codesign identity: `build.mac.identity` in package.json pins
# "Apple Development: Hao Pan (78R7UX7VV7)" so the other team’s Apple Development cert is not auto-picked.
# Optional override (wins over package.json):
# CSC_NAME=…
#
# Notarized distribution outside the App Store still requires signing with
# Developer ID Application — replace mac.identity (or set CSC_NAME) when you ship that way.
