{
  "name": "desktop",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently --kill-others --success first -n renderer,tsc,electron \"npm run dev:renderer\" \"npm run dev:electron:tsc\" \"npm run dev:electron:run\"",
    "dev:renderer": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:electron:tsc": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron:run": "wait-on tcp:5173 file:dist-electron/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron dist-electron/main.js",
    "build": "tsc -p tsconfig.electron.json && vite build"
  },
  "dependencies": {
    "@dartsnut/agent-runtime": "0.1.0",
    "@dartsnut/shared-ipc": "0.1.0",
    "dotenv": "^16.5.0",
    "electron": "^35.1.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.10",
    "vite": "^6.3.5"
    ,
    "wait-on": "^8.0.3"
  }
}
